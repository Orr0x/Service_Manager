# Local development environment template (Ubuntu/Linux)
# Copy to .env.local or .env and replace placeholder values with your own.
# Never commit real secret values.

# Required for app runtime
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase now shows publishable keys for new projects. Either publishable or anon works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-jwt

# Required for admin scripts and some server-side actions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional integrations
WHAT3WORDS_API_KEY=your-what3words-api-key
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token
TOMTOM_API_KEY=your-tomtom-api-key

# Optional direct DB connection used by helper scripts and migrations
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
POSTGRES_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_CONNECTION_STRING=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Optional test config
PLAYWRIGHT_BASE_URL=http://localhost:3000
